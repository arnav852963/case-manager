

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
  envFile = "./.env"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}




enum Role {
  ADMIN
  MANAGER
  FINANCE
  CLIENT
}

enum CaseStatus {
  PENDING
  UNDER_REVIEW
  IN_PROGRESS
  COMPLETED
  CLOSED
}

enum ServiceStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  UPI
  CARD
  BANK_TRANSFER
  CASH
  OTHER
}

enum ActionType {
  CREATE
  UPDATE
  DELETE
  ASSIGN
  PAYMENT
  LOGIN
  LOGOUT
}


model User {
  id             String          @id @default(uuid())
  name           String
  email          String          @unique
  passwordHash   String
  role           Role
  createdCases   Case[]          @relation("CreatedCases")
  assignedCases  Case[]          @relation("AssignedCases")
  serviceRecords ServiceRecord[]
  payments       Payment[]
  auditLogs      AuditLog[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Case {
  id             String           @id @default(uuid())
  title          String
  description    String
  currentStatus  CaseStatus       @default(PENDING)
  createdBy      User             @relation("CreatedCases", fields: [createdById], references: [id])
  createdById    String
  assignedTo     User?            @relation("AssignedCases", fields: [assignedToId], references: [id])
  assignedToId   String?
  serviceRecords ServiceRecord[]
  payment        Payment?
  auditLogs      AuditLog[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model ServiceRecord {
  id           String        @id @default(uuid())
  case         Case          @relation(fields: [caseId], references: [id])
  caseId       String
  oldStatus    CaseStatus?
  newStatus    CaseStatus
  description  String?
  updatedBy    User          @relation(fields: [updatedById], references: [id])
  updatedById  String
  createdAt    DateTime      @default(now())
}

model Payment {
  id             String          @id @default(uuid())
  case           Case            @relation(fields: [caseId], references: [id])
  caseId         String
  amount         Float
  currency       String           @default("INR")
  status         PaymentStatus    @default(PENDING)
  transactionId  String?          // External gateway ID (Stripe, Razorpay, etc.)
  referenceCode  String?          // Internal tracking code
  paymentMethod  PaymentMethod
  invoiceUrl     String?
  remarks        String?
  processedBy    User?            @relation(fields: [processedById], references: [id])
  processedById  String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model AuditLog {
  id         String      @id @default(uuid())
  user       User        @relation(fields: [userId], references: [id])
  userId     String
  entity     String       // "Case", "Payment", "User", etc.
  entityId   String
  action     ActionType
  details    Json?
  timestamp  DateTime     @default(now())
}



